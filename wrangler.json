{
  "name": "my-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-03-31",
  "workers_dev": true,

  "routes": [],
  "account_id": "YOUR_ACCOUNT_ID",

  "vars": {
    "ENVIRONMENT": "development"
  },

  "kv_namespaces": [
    {
      "binding": "MY_KV",
      "id": "YOUR_KV_NAMESPACE_ID"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "MY_OBJECT",
        "class_name": "MyDurableObject"
      }
    ]
  },

  "r2_buckets": [
    {
      "binding": "MY_BUCKET",
      "bucket_name": "my-bucket"
    }
  ]
}
